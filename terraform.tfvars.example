# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is in .gitignore — never commit secrets.

aws_region = "ap-southeast-1"

# Instance sizes (t3.micro is free tier eligible)
app_instance_type = "t3.micro"
db_instance_type  = "t3.micro"

# Generate SSH key pair:  ssh-keygen -t rsa -b 4096 -f ~/.ssh/terraform-key
# Then paste the contents of ~/.ssh/terraform-key.pub below
ssh_public_key = "ssh-rsa AAAAB3NzaC1yc2EAAA... your-public-key-here"

# Database credentials
db_name     = "restaurant_pos"
db_user     = "restaurant"
db_password = "change-me-strong-password"

# After running ecr/up.sh, paste the instance_profile_name output here:
# ec2_instance_profile = "restaurant-ec2-ecr-pull"

# After running storage/up.sh, paste the volume_id output here:
# mysql_data_volume_id = "vol-0abc123def456789"

